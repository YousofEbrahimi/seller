# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-YOUR-TOKEN-HERE

# Admin Telegram numeric IDs (comma-separated). Get yours from @userinfobot
ADMIN_IDS=123456789

# Database URL. Two options:
#   SQLite (local/test):    sqlite:///seller.db
#   MySQL (alwaysdata):     mysql+pymysql://USER:PASS@mysql-HOST.alwaysdata.net/DBNAME?charset=utf8mb4
#   On alwaysdata, get HOST from the admin panel → Databases → your MySQL instance.
#   Create a database + user from the alwaysdata web admin first.
DATABASE_URL=sqlite:///seller.db

# Secret salt for download tokens
DOWNLOAD_TOKEN_SALT=change-this-to-a-random-string

# Telegram API base URL (leave empty for direct; set to a Deno Deploy proxy URL if blocked)
# Example: https://tg-proxy.deno.dev
TELEGRAM_API_BASE=

# HTTP/SOCKS5 proxy (optional, only if direct access is blocked)
PROXY_HOST=
PROXY_PORT=
PROXY_TYPE=HTTP

# Store name (shown in bot)
STORE_NAME=فروشگاه فایل
